# Les Aliments Benito environment settings
NODE_ENV=development
PORT=3000

# Admin user created on first startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

# SMTP / email settings
SMTP_USER=
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_FROM=
ORDER_EMAIL=

# Optional database settings
# DATABASE_URL=postgres://user:password@localhost:5432/benito

# Session settings
SESSION_TTL_MS=28800000

# Optional advanced email backends
# GOOGLE_SCRIPT_URL=
# GOOGLE_SCRIPT_SECRET=
